{
  "name": "tablito",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "build-android-dev": "eas build -p android --profile development --local",
    "build-android-preview": "eas build -p android --profile preview",
    "build-android-preview-local": "bash -c 'set -a; source .env; set +a; eas build -p android --profile preview --local'",
    "build-android": "eas build -p android --profile production",
    "build-android-apk": "eas build -p android --profile production-apk",
    "build-android-apk-local": "eas build -p android --profile production-apk --local --clear-cache",
    "submit-android": "eas submit --platform android"
  },
  "dependencies": {
    "@expo/ui": "~57.0.3",
    "expo": "~57.0.2",
    "expo-constants": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-router": "~57.0.3",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "typescript": "~6.0.3"
  },
  "private": true
}
